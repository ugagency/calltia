# Copie este arquivo para .env.local e preencha com os valores reais.
# Nunca commitar .env / .env.local (ver .gitignore). Passo a passo de onde
# obter cada valor está em SETUP.md.

# Supabase — Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# nunca prefixar com NEXT_PUBLIC_. Usada só em lib/supabase/admin.ts.
SUPABASE_SERVICE_ROLE_KEY=
# Motor de voz ativo. "vapi" é o único implementado hoje; "pipecat" fica
# reservado para a migração futura (ver src/lib/voz/pipecat.ts).
MOTOR_DE_VOZ=vapi

# Vapi — dashboard.vapi.ai > API Keys.
VAPI_API_KEY=
# Id do número de telefone cadastrado no Vapi (vinculado ao trunk SIP
# nacional). dashboard.vapi.ai > Phone Numbers.
VAPI_PHONE_NUMBER_ID=
# Segredo compartilhado do webhook do Vapi. Configure o MESMO valor no campo
# de secret do Server URL no Vapi; o endpoint /api/webhooks/vapi rejeita
# qualquer requisição cujo header x-vapi-secret não bata com este valor.
# Gere com: openssl rand -hex 32
VAPI_WEBHOOK_SECRET=

# Opcionais — se vazios, o VapiMotor usa defaults (gpt-4o-mini / voz padrão
# 11labs). Preencha para customizar o assistente.
VAPI_MODELO=
VAPI_VOICE_ID=

# Segredo das operações de servidor da Vettia (discador e controle de
# campanha). O agendador externo (cron-job.org) precisa enviar este valor no
# header "Authorization: Bearer <CRON_SECRET>" a cada chamada — não é
# injetado automaticamente. Use o mesmo bearer para iniciar campanhas.
# Gere com: openssl rand -hex 32
CRON_SECRET=
